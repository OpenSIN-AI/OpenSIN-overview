# EditorConfig — https://editorconfig.org
# Consistent editor behaviour across every contributor (and agent).

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.md]
# Markdown: preserve intentional trailing spaces (= hard line break)
trim_trailing_whitespace = false
max_line_length = off

[*.{yml,yaml}]
indent_size = 2

[*.json]
indent_size = 2

[*.js]
indent_size = 2

[*.sh]
indent_size = 2

[Makefile]
indent_style = tab
