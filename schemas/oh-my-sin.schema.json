{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/OpenSIN-AI/OpenSIN-overview/blob/main/schemas/oh-my-sin.schema.json",
  "title": "OpenSIN Marketplace Aggregator",
  "description": "The aggregated marketplace registry consumed by website-my.opensin.ai/marketplace and mirrored into Infra-SIN-OpenCode-Stack. Generated by scripts/build-oh-my-sin.js from every templates/teams/*.json. Validated per Wave-4 Option A — do NOT hand-edit.",
  "type": "object",
  "required": ["$schema_version", "generated_at", "generator", "org", "ssot", "counts", "tiers", "teams"],
  "additionalProperties": false,
  "properties": {
    "$schema_version": {
      "type": "string",
      "const": "1.0.0",
      "description": "Aggregator format version. Bump requires updating this schema and every consumer."
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp the aggregator was built. Consumers may cache on this field."
    },
    "generator": {
      "type": "string",
      "const": "OpenSIN-overview/scripts/build-oh-my-sin.js",
      "description": "Tool that produced this file. Hand-edits are forbidden."
    },
    "org": {
      "type": "string",
      "const": "OpenSIN-AI"
    },
    "ssot": {
      "type": "object",
      "required": ["schema", "manifests_dir"],
      "additionalProperties": false,
      "properties": {
        "schema": {"type": "string", "description": "Path to the per-team schema, relative to this repo's root."},
        "manifests_dir": {"type": "string", "description": "Directory holding per-team manifests, relative to this repo's root."}
      }
    },
    "counts": {
      "type": "object",
      "required": ["total", "by_tier", "by_status", "listable", "agents_referenced"],
      "additionalProperties": false,
      "properties": {
        "total": {"type": "integer", "minimum": 0},
        "by_tier": {
          "type": "object",
          "patternProperties": {
            "^(marketplace|core-included|enterprise)$": {"type": "integer", "minimum": 0}
          },
          "additionalProperties": false
        },
        "by_status": {
          "type": "object",
          "patternProperties": {
            "^(stable|beta|alpha|coming-soon|deprecated)$": {"type": "integer", "minimum": 0}
          },
          "additionalProperties": false
        },
        "listable": {"type": "integer", "minimum": 0, "description": "Teams that should appear on the public marketplace (not coming-soon / deprecated)."},
        "agents_referenced": {"type": "integer", "minimum": 0, "description": "Unique A2A-SIN-* agent IDs across all teams."}
      }
    },
    "tiers": {
      "type": "object",
      "required": ["core-included", "marketplace", "enterprise"],
      "additionalProperties": false,
      "properties": {
        "core-included": {"type": "array", "items": {"type": "string", "pattern": "^Team-SIN-[A-Za-z][A-Za-z0-9-]*$"}},
        "marketplace":   {"type": "array", "items": {"type": "string", "pattern": "^Team-SIN-[A-Za-z][A-Za-z0-9-]*$"}},
        "enterprise":    {"type": "array", "items": {"type": "string", "pattern": "^Team-SIN-[A-Za-z][A-Za-z0-9-]*$"}}
      }
    },
    "teams": {
      "type": "array",
      "minItems": 0,
      "items": {"$ref": "#/$defs/AggregatedTeam"}
    }
  },
  "$defs": {
    "AggregatedTeam": {
      "type": "object",
      "required": ["id", "slug", "name", "tier", "status", "status_label", "pricing", "pricing_label", "agents", "agent_count", "primary_agents", "permissions", "marketing", "budgets", "provenance", "links", "source_file"],
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string", "pattern": "^Team-SIN-[A-Za-z][A-Za-z0-9-]*$"},
        "slug": {"type": "string", "pattern": "^[a-z][a-z0-9-]{2,40}$"},
        "name": {"type": "string", "minLength": 3, "maxLength": 60},
        "tagline": {"type": "string", "maxLength": 140},
        "tier": {"type": "string", "enum": ["marketplace", "core-included", "enterprise"]},
        "status": {"type": "string", "enum": ["stable", "beta", "alpha", "coming-soon", "deprecated"]},
        "status_label": {"type": "string"},
        "pricing": {
          "type": "object",
          "description": "Passthrough of team.pricing.",
          "properties": {
            "model": {"type": "string", "enum": ["free-with-pro", "monthly-addon", "metered", "enterprise-quote"]},
            "monthly_addon_eur": {"type": "number", "minimum": 0, "maximum": 999},
            "metered_unit": {"type": "string"},
            "metered_unit_price_eur": {"type": "number", "minimum": 0},
            "stripe_product_id": {"type": "string", "pattern": "^prod_[A-Za-z0-9]+$"}
          },
          "additionalProperties": false
        },
        "pricing_label": {"type": "string", "description": "Human-readable price (e.g. '€9/month add-on'). Marketplace UI may use directly."},
        "agents": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "role"],
            "additionalProperties": false,
            "properties": {
              "id": {"type": "string", "pattern": "^A2A-SIN-[A-Za-z][A-Za-z0-9-]*$"},
              "role": {"type": "string", "enum": ["primary", "supporting", "optional"]},
              "summary": {"type": "string", "maxLength": 180}
            }
          }
        },
        "agent_count": {"type": "integer", "minimum": 0},
        "primary_agents": {"type": "array", "items": {"type": "string", "pattern": "^A2A-SIN-[A-Za-z][A-Za-z0-9-]*$"}},
        "permissions": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "read:user-memory",
              "write:user-memory",
              "net:external-http",
              "net:cloud-apis",
              "spend:llm-budget",
              "spend:user-managed-credentials",
              "filesystem:user-workspace",
              "shell:user-workspace"
            ]
          }
        },
        "marketing": {
          "type": "object",
          "required": ["summary", "bullets"],
          "additionalProperties": false,
          "properties": {
            "summary": {"type": "string", "maxLength": 600},
            "bullets": {"type": "array", "items": {"type": "string", "maxLength": 180}},
            "screenshot": {"type": ["string", "null"]},
            "demo_video": {"type": ["string", "null"]}
          }
        },
        "budgets": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "default_monthly_usd_cap": {"type": "number", "minimum": 0},
            "per_run_usd_cap": {"type": "number", "minimum": 0}
          }
        },
        "provenance": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "decided_in": {"type": "string"},
            "decided_at": {"type": "string", "format": "date"},
            "owner_team": {"type": "string"}
          }
        },
        "links": {
          "type": "object",
          "required": ["repo", "marketplace"],
          "additionalProperties": false,
          "properties": {
            "repo": {"type": "string", "format": "uri"},
            "marketplace": {"type": "string", "format": "uri"}
          }
        },
        "source_file": {"type": "string", "description": "Path to the per-team manifest this entry was generated from."}
      }
    }
  }
}
